# ChitraGupta 2.0 — Backend Environment Variables
# Copy this file to .env and fill in values

# Supabase (required for database + auth)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# CORS (comma-separated origins for production deployments)
CORS_ORIGINS=https://your-frontend.vercel.app,https://another-frontend.vercel.app

# AI Provider API Keys (at least one required for chat)
GROQ_API_KEY=your-groq-key
GOOGLE_API_KEY=your-google-key
MISTRAL_API_KEY=your-mistral-key
OPENAI_API_KEY=your-openai-key

# Logging
LOG_LEVEL=INFO